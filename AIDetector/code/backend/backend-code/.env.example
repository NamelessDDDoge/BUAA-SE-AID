# Database
# DATABASE_MODE:
# - local: default local SQLite
# - aliyun_postgres: configured Aliyun PostgreSQL, optional SSH tunnel
# - custom: keep using DB_* / MYSQL_* legacy custom configuration
DATABASE_MODE=local
LOCAL_DB_NAME=db.sqlite3


